{
	"name": "@salesmind-ai/n8n-nodes-vertex-advanced-chat-model",
	"version": "1.0.1",
	"description": "n8n community node for Google Vertex AI Chat Model with labels support for billing cost tracking",
	"license": "MIT",
	"homepage": "https://github.com/SalesMindAI/n8n-nodes-vertex-advanced-chat-model",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Florent Duthoit",
		"email": "florent.duthoit@sales-mind.ai"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/SalesMindAI/n8n-nodes-vertex-advanced-chat-model.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
