		"@google-cloud/resource-manager": "5.3.0",
		"@langchain/google-vertexai": "2.0.0"
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/lodash": "^4.17.24",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"@langchain/core": ">=1.1.0",
		"n8n-workflow": "*"
